body{
    margin:0;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    background:#1f2937;
    font-family:Arial,sans-serif;
}

.calculator{
    background:#111827;
    padding:20px;
    border-radius:15px;
    width:320px;
    box-shadow:0 0 20px rgba(0,0,0,.4);
}

#display{
    width:100%;
    height:60px;
    font-size:28px;
    text-align:right;
    border:none;
    border-radius:10px;
    margin-bottom:15px;
    padding-right:10px;
}

.buttons{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:10px;
}

button{
    height:60px;
    font-size:22px;
    border:none;
    border-radius:10px;
    cursor:pointer;
    background:#374151;
    color:white;
}

button:hover{
    background:#4b5563;
}

button:last-child{
    grid-column:span 2;
    background:#2563eb;
}